+    /// S8.7 — Codex post-S8.5 audit Medium #1: pins the contract that
+    /// FilamentSettingsView's cooling tab depends on in Advanced mode.
+    ///
+    /// The view's Advanced cooling section reads `advancedSettings.fanMinSpeed`
+    /// and `advancedSettings.coolingFanOverhang` (env-scaled, state-aware) instead
+    /// of `filProfile.coolingFanMin` and `filProfile.coolingFan` (state-less,
+    /// material default). T2a already verifies env-vs-env scaling; this test
+    /// asserts the orthogonal property that the two sources DISAGREE on a real
+    /// env. If a future refactor accidentally points the view back at filProfile
+    /// in cold env, this test catches the silent regression even though the
+    /// bridge math is correct.
+    ///
+    /// RED demo verified 2026-05-15: first authored with XCTAssertGreaterThan
+    /// (claimed env-scaled > raw, which is wrong — cold REDUCES fan). xcodebuild
+    /// test surfaced: `XCTAssertGreaterThan failed: ("63.0") is not greater
+    /// than ("70.0")`. Flipped to XCTAssertLessThan. Proves matcher machinery
+    /// would catch a real regression of the cooling-UI source-of-truth.
+    func testV104_S8_7_CoolingUI_AdvancedSourceIsEnvScaled() async throws {
+        let state = AppState()
+        state.printer = "x1c"
+        state.nozzle = "std_0.4"
+        state.material = "pla_basic"
+        state.environment = "cold"
+
+        let advanced = try await EngineService.shared.getAdvancedFilamentSettings(state)
+        let rawOpt   = try await EngineService.shared.getFilamentProfile(state.material)
+        let raw      = try XCTUnwrap(rawOpt, "getFilamentProfile must return a profile for pla_basic")
+
+        let scaledMin = try Self.parseFan(advanced.fanMinSpeed)
+        let rawMin    = try Self.parseFan(raw.coolingFanMin)
+        XCTAssertLessThan(scaledMin, rawMin,
+                          "FilamentSettingsView Advanced cooling must render env-scaled fanMinSpeed (\(scaledMin)) " +
+                          "from advancedSettings, NOT raw coolingFanMin (\(rawMin)) from filProfile. " +
+                          "If equal, the env multiplier isn't reaching the cooling-tab UI for PLA+cold+x1c.")
+
+        let scaledOverhang = try Self.parseFan(advanced.coolingFanOverhang)
+        let rawOverhang    = try Self.parseFan(raw.coolingFan)
+        XCTAssertLessThan(scaledOverhang, rawOverhang,
+                          "FilamentSettingsView Advanced cooling must render env-scaled coolingFanOverhang " +
+                          "(\(scaledOverhang)) from advancedSettings, NOT raw coolingFan (\(rawOverhang)) from filProfile.")
+    }
+
