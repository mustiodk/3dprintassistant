+    /// Mirrors walkthrough [v1.0.4 P1.5 HIGH-01-export]: text + Bambu Studio export use env-scaled fan
+    /// (63/90 for PLA+cold) + enable_draft_shield='1'.
+    func testV104_P1_5_HIGH01_ExportEnvFanDraftShield() async throws {
+        let state = AppState()
+        state.printer = "x1c"
+        state.nozzle = "std_0.4"
+        state.material = "pla_basic"
+        state.environment = "cold"
+
+        let txtMaybe = try await EngineService.shared.formatProfileAsText(state)
+        let txt = try XCTUnwrap(txtMaybe, "formatProfileAsText returned nil for x1c+cold")
+        // Match the web walkthrough's exact coverage shape: text export asserts fan_min only
+        // (`/Fan speed \(min\):\s*([\d]+)/`). The text export uses the label "Part cooling fan"
+        // for max — but fan_max env-scaling is covered authoritatively by the BS export check below.
+        let fanMinRe = try NSRegularExpression(pattern: #"Fan speed \(min\):\s*(\d+)"#)
+        let fanMinHit = fanMinRe.firstMatch(in: txt, range: NSRange(txt.startIndex..., in: txt))
+        XCTAssertNotNil(fanMinHit, "text export must contain 'Fan speed (min): N' line; first 800 chars:\n\(txt.prefix(800))")
+        if let m = fanMinHit, let r = Range(m.range(at: 1), in: txt) {
+            XCTAssertEqual(String(txt[r]), "63", "text export Fan speed (min) should be env-scaled 63 (70×0.9)")
+        }
+
+        let bsMaybe = try await EngineService.shared.exportBambuStudioJSON(state)
+        let bs = try XCTUnwrap(bsMaybe, "exportBambuStudioJSON returned nil for x1c+cold")
+        let draftShield = bs.process["enable_draft_shield"]
+        XCTAssertEqual(draftShield as? String, "1",
+                       "BS process.enable_draft_shield should be '1' on cold env; got: \(String(describing: draftShield))")
+        // Bambu Studio filament fields are arrays (one per AMS slot) — web walkthrough uses
+        // `bs.filament.fan_min_speed?.[0]`. Mirror on iOS via NSArray cast.
+        let bsFanMin = Self.firstFromBSArray(bs.filament["fan_min_speed"])
+        let bsFanMax = Self.firstFromBSArray(bs.filament["fan_max_speed"])
+        XCTAssertEqual(bsFanMin, "63",
+                       "BS filament.fan_min_speed[0] should be 63 (env-scaled); got: \(String(describing: bs.filament["fan_min_speed"]))")
+        XCTAssertEqual(bsFanMax, "90",
+                       "BS filament.fan_max_speed[0] should be 90 (env-scaled); got: \(String(describing: bs.filament["fan_max_speed"]))")
+    }
