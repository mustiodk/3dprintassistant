+        let bedNormal: Double = try Self.parseTemp(advNormal.initialLayerBedTemp)
+        let bedCold: Double = try Self.parseTemp(advCold.initialLayerBedTemp)
+        XCTAssertEqual(bedCold - bedNormal, 7.0, accuracy: 0.01,
+                       "cold should raise first-layer bed by env.cold.bed_first_layer_adj=+7°C (got cold=\(bedCold), normal=\(bedNormal))")
