+            let claimRe = try NSRegularExpression(pattern: #"\+\s*(\d+)\s*°?C"#, options: .caseInsensitive)
+            if let m = claimRe.firstMatch(in: body, range: NSRange(body.startIndex..., in: body)),
+               let r = Range(m.range(at: 1), in: body),
