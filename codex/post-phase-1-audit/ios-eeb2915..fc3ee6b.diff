+    // MARK: - v1.0.4 test helpers
+
+    /// Helper: strip ` mm/s` / ` mm` / `%` / `°C` units from a ProfileParam.value and parse as Double.
+    private static func numeric(_ param: ProfileParam?) throws -> Double {
+        let value = try XCTUnwrap(param?.value, "missing param")
+        let stripped = value
+            .replacingOccurrences(of: " mm/s", with: "")
+            .replacingOccurrences(of: " mm", with: "")
+            .replacingOccurrences(of: "°C", with: "")
+            .replacingOccurrences(of: "%", with: "")
+            .trimmingCharacters(in: .whitespaces)
+        return try XCTUnwrap(Double(stripped), "value '\(value)' not numeric")
+    }
+
+    /// Helper: parse a temperature string like "55 °C" / "110°C" / "85 C" into a Double.
+    /// Tolerates either spaced or unspaced unit, with or without the ° glyph.
+    private static func parseTemp(_ raw: String) throws -> Double {
+        let stripped = raw
+            .replacingOccurrences(of: "°C", with: "")
+            .replacingOccurrences(of: "°", with: "")
+            .replacingOccurrences(of: "C", with: "")
+            .trimmingCharacters(in: .whitespaces)
+        return try XCTUnwrap(Double(stripped), "value '\(raw)' not parseable as temperature")
+    }
+
+    /// Helper: coerce Any? (typed as String / Int / Double) → its base-10 integer string,
+    /// for permissive comparison against BambuStudio export fields that are marshaled
+    /// inconsistently (some `"1"`, some `1`, some `1.0`).
+    private static func toIntString(_ x: Any?) -> String? {
+        if let s = x as? String { return s }
+        if let i = x as? Int { return String(i) }
+        if let d = x as? Double { return String(Int(d)) }
+        return nil
+    }
+
+    /// Helper: Bambu Studio filament-section fields are JSON arrays (one entry per AMS
+    /// slot). Cast to NSArray, take the first element, coerce to int-string.
+    /// Mirrors the web walkthrough's `bs.filament.fan_min_speed?.[0]` access pattern.
+    private static func firstFromBSArray(_ x: Any?) -> String? {
+        guard let arr = x as? NSArray, arr.count > 0 else { return nil }
+        return toIntString(arr[0])
+    }
