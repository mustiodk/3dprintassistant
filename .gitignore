.DS_Store
.claude/
node_modules/
.wrangler/

# Printer Intake Scout — local secret config, run state, and staging output
# (run reports + candidate skeletons can contain requester notes — never commit).
scripts/.printer-intake.local.json
scripts/.printer-intake.watermark.json
scripts/.printer-intake-retrospective.watermark.json
scripts/.printer-intake-out/
# republish-overlay.js validate-then-swap temp (a crash between write and
# rename must not dirty the tree — the runner preflight fail-closes on dirt).
catalog/*.republish-tmp

# Intake Autonomy v2 runner state (Gate B3). NOTE: .intake-runner-state/ is
# the runner's DURABLE local state (parked candidates, run reports, digest
# offset) — deliberately separate from .printer-intake-out/, which the Scout
# test suite rmSync-wipes (see gate ledger B1 row).
scripts/.intake-autonomy-freeze
scripts/.intake-run.lock
scripts/.printer-intake-runner.watermark.json
scripts/.intake-runner-state/

